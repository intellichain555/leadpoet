{
  "name": "Crunchbase US Companies",
  "icp_text": "US-based companies across all industries. Target executive and senior decision-makers such as CEO, CTO, Founder, President, VP, Director, Partner, COO, CMO, and other C-suite or leadership roles for business development, partnership, and sales opportunities.",
  "queries": [],
  "required_fields": {
    "company": ["name", "industry", "sub_industry"],
    "contact": ["email", "job_title", "full_name"]
  },
  "optional_fields": {
    "company": ["hq_location", "revenue_range", "employee_count", "specialties", "founded_year", "company_type", "number_of_locations", "ownership_type"],
    "contact": ["phone", "linkedin_url", "decision_maker", "department", "seniority"]
  },
  "threshold": 0.2,
  "filtering_strict": false,
  "mode": "fast",
  "refresh_policy": {
    "revisit_after_days": 90,
    "failure_revisit_days": 7,
    "domain_serp_ttl_hours": 48,
    "crawl_ttl_days": 14,
    "enrich_ttl_days": 30
  },
  "concurrency": {
    "max_concurrent_requests": 3
  },
  "search": {
    "max_pages": 1,
    "max_results_per_query": 30
  },
  "testing": {
    "process_rejected": true,
    "process_low_crawl": true,
    "force_contact_discovery": true
  },
  "caps": {
    "company_usd": 0.02,
    "contact_usd": 0.03,
    "run_usd_max": 5.0,
    "max_domains_per_run": 10,
    "max_crawl_per_run": 10,
    "max_enrich_per_run": 10
  },
  "role_priority": {
    "ceo": 1,
    "cto": 1,
    "co-founder": 1,
    "founder": 1,
    "president": 1,
    "owner": 1,
    "managing partner": 1,
    "partner": 2,
    "coo": 2,
    "cfo": 2,
    "cmo": 2,
    "chief revenue officer": 2,
    "chief growth officer": 2,
    "chief strategy officer": 2,
    "chief people officer": 2,
    "chief technology officer": 2,
    "chief product officer": 2,
    "vp of engineering": 2,
    "vp of sales": 2,
    "vp of marketing": 2,
    "vp of product": 2,
    "vp of operations": 2,
    "vp of business development": 2,
    "vp of technology": 2,
    "general manager": 2,
    "director of engineering": 3,
    "director of marketing": 3,
    "director of sales": 3,
    "director of operations": 3,
    "director of product": 3,
    "director of business development": 3,
    "head of growth": 3,
    "head of engineering": 3,
    "head of marketing": 3,
    "head of sales": 3,
    "default": 99
  },
  "exports": {
    "enabled": true
  },
  "default_country": "US",
  "exclusion_criteria": {
    "ownership_types": [],
    "max_locations": 10000,
    "excluded_keywords": []
  },
  "targeting": {
    "location_types": ["headquarters", "single_location"],
    "company_sizes": ["small", "mid-market", "enterprise"],
    "ownership_models": ["private"],
    "geographic_focus": ["North America", "United States"]
  },
  "intent_config": {
    "purpose": "us_business_development",
    "target_action": "partnership_sales",
    "intent_signals": {
      "high_intent": [],
      "medium_intent": [],
      "low_intent": []
    },
    "intent_sources": [
      "about_pages",
      "team_pages",
      "contact_pages",
      "careers_pages"
    ],
    "scoring_rules": {
      "high_intent_weight": 0.8,
      "medium_intent_weight": 0.4,
      "low_intent_weight": -0.1,
      "base_score": 0.5,
      "location_bonus": 0.1,
      "size_bonus": 0.1,
      "leadership_bonus": 0.15
    }
  }
